       "Default 1.0 = ~14%. Naikkan ke 1.5 = ~20%, turunkan ke 0.7 = ~10%.")

// ── Risiko Likuiditas & Gorengan (BARU di V2) ──
grupRisiko = "Risiko Likuiditas & Gorengan"

tampilRisikoGorengan = input.bool(true, "Tampilkan Modul Risiko Likuiditas", group = grupRisiko)
ambangARA        = input.float(24.0, "Ambang Deteksi ARA/ARB (%)", minval = 1, group = grupRisiko,
     tooltip = "Persentase perubahan harga harian yang dianggap 'mendekati/kena batas ARA-ARB'. " +
       "Aturan ARA/ARB IDX bertingkat menurut harga & pernah berubah — sesuaikan sendiri sesuai " +
       "aturan yang berlaku saat ini. Ini adalah proxy, bukan aturan resmi bursa.")
lookbackARA       = input.int(20, "Lookback Hari untuk Hitung ARA/ARB", minval = 5, maxval = 60, group = grupRisiko)
kapKecilMiliar    = input.float(1000, "Ambang Kapitalisasi 'Kecil' (Miliar Rp)", group = grupRisiko)
kapBesarMiliar    = input.float(10000, "Ambang Kapitalisasi 'Besar' (Miliar Rp)", group = grupRisiko)
likuiditasRendahJt = input.float(500, "Ambang Nilai Transaksi Harian 'Rendah' (Juta Rp, avg 20D)", group = grupRisiko)
likuiditasTinggiJt = input.float(20000, "Ambang Nilai Transaksi Harian 'Tinggi' (Juta Rp, avg 20D)", group = grupRisiko)
hargaRecehan      = input.float(50, "Ambang Harga 'Recehan' (Rp)", group = grupRisiko)

posisiTabel = switch posisiInput
    "Kiri Atas"    => position.top_left
    "Kanan Bawah"  => position.bottom_right
    "Kiri Bawah"   => position.bottom_left
    => position.top_right

ukuranTeks = switch ukuranTeksInput
    "Kecil Sekali" => size.tiny
    "Normal"       => size.normal
