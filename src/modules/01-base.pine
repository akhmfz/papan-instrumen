gunakanBobotKustom = input.bool(false, "Gunakan Bobot Kustom (default: 6 faktor sama rata)", group = grupBobot)
bobotValue     = input.float(1.0, "Bobot Value", minval = 0, step = 0.1, group = grupBobot)
