bobotGrowth    = input.float(1.0, "Bobot Growth", minval = 0, step = 0.1, group = grupBobot)
bobotHealth    = input.float(1.0, "Bobot Health", minval = 0, step = 0.1, group = grupBobot)
bobotMomentum  = input.float(1.0, "Bobot Momentum", minval = 0, step = 0.1, group = grupBobot)
bobotIncome    = input.float(1.0, "Bobot Income", minval = 0, step = 0.1, group = grupBobot)
bobotIndonesia = input.float(1.0, "Bobot Indonesia Factor", minval = 0, step = 0.1, group = grupBobot,
