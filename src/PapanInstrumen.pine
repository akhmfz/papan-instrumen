altBg = isLightTheme ? color.rgb(235, 238, 243) :
     isEmerald ? color.rgb(7, 27, 22) :
     isRoyal ? color.rgb(10, 20, 45) :
     isAmber ? color.rgb(29, 23, 13) :
     color.rgb(10, 20, 36)

headerBg = isLightTheme ? color.rgb(215, 220, 228) :
