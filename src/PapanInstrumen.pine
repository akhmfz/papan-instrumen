//══════════════════════════════
//
// MODUL 02
// TEMA WARNA
//
//══════════════════════════════
isLightTheme = warnaTema == "Profesional Terang"
isEmerald    = warnaTema == "Bursa Hijau"
isRoyal      = warnaTema == "Biru Nusantara"
