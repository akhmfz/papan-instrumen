      {"name": "indoValTradedJt", "type": "float", "computedFrom": ["valTradedAvg20"], "usedIn": "indonesia"},
      {"name": "indoTurnoverPct", "type": "float", "computedFrom": ["volAvg20", "sharesOut"], "usedIn": "indonesia"},
      {"name": "mcapMiliar", "type": "float", "computedFrom": ["mcap"], "usedIn": "risk"},
      {"name": "valTradedJt", "type": "float", "computedFrom": ["valTradedAvg20"], "usedIn": "risk"},
      {"name": "turnoverPct", "type": "float", "computedFrom": ["volAvg20", "sharesOut"], "usedIn": "risk"},
      {"name": "effectiveBobotIndonesia", "type": "float", "computedFrom": ["bobotIndonesia", "wIndonesia"], "usedIn": "overallScore (weighted mode)"},
      {"name": "noData", "type": "bool", "computedFrom": ["epsTtm", "bvps", "roe", "debtEq", "divYield"], "usedIn": "render (guards all sections)"},
      {"name": "isEN", "type": "bool", "computedFrom": ["bahasa"], "usedIn": "render (language switch)"}
    ]
  },

